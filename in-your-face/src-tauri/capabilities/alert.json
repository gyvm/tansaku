{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "alert",
  "description": "Capabilities for alert overlay windows",
  "windows": ["alert-*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-focus",
    "shell:allow-open"
  ]
}
