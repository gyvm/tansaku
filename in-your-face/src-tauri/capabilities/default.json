{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:menu:default",
    "core:tray:default",
    "store:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "notification:default",
    "shell:allow-open",
    "oauth:allow-start",
    "oauth:allow-cancel",
    "opener:default"
  ]
}
